[MASTER]
ignore=venv
jobs=1

[MESSAGES CONTROL]
disable=
    missing-module-docstring,
    missing-class-docstring,
    missing-function-docstring,
    invalid-name,
    too-few-public-methods,
    broad-except

[FORMAT]
max-line-length=100

[BASIC]
good-names=i,j,k,ex,Run,_,X,y,df,id

[DESIGN]
max-args=8
max-locals=20

[REPORTS]
output-format=text
score=yes
